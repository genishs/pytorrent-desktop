# Normalize line endings: LF in the repo, auto-convert on checkout.
* text=auto eol=lf

# Explicitly text
*.py    text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.txt   text eol=lf
*.gitattributes text eol=lf
*.gitignore     text eol=lf

# Binary assets (never touched)
*.png   binary
*.ico   binary
*.icns  binary
*.torrent binary
